  "components": {
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "username": {
            "type": "string"
          },
          "role": {
            "type": "string",
            "enum": [
              "user",
              "judge",
              "admin"
            ]
          },
          "created_at": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "username",
          "role",
          "created_at"
        ]
      },
      "Problem": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "time_limit_ms": {
            "type": "integer"
          },
          "memory_limit_mb": {
            "type": "integer"
          },
          "description": {
            "type": "string"
          },
          "input_spec": {
            "type": "string"
          },
          "output_spec": {
            "type": "string"
          }
        },
        "required": [
          "code",
          "title",
          "time_limit_ms",
          "memory_limit_mb",
          "description",
          "input_spec",
          "output_spec"
        ]
      },
      "TestCase": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "input": {
            "type": "string"
          },
          "output": {
            "type": "string"
          },
          "is_sample": {
            "type": "boolean"
          }
        },
        "required": [
          "id",
          "input",
          "output",
          "is_sample"
        ]
      },
      "Submission": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "problem_id": {
            "type": "integer"
          },
          "language": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "score": {
            "type": "integer"
          },
          "time_ms": {
            "type": "integer"
          },
          "memory_kb": {
            "type": "integer"
          },
          "details": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "testcase_id": {
                  "type": "integer"
                },
                "status": {
                  "type": "string"
                },
                "time_ms": {
                  "type": "integer"
                }
              },
              "required": [
                "testcase_id",
                "status",
                "time_ms"
              ]
            }
          }
        },
        "required": [
          "id",
          "problem_id",
          "status",
          "score",
          "time_ms",
          "memory_kb",
          "details"
        ]
      },
      "Solution": {
        "type": "object",
        "properties": {
          "user_id": {
            "type": "integer"
          },
          "problem_id": {
            "type": "integer"
          },
          "language": {
            "type": "string"
          },
          "source_code": {
            "type": "string"
          }
        },
        "required": [
          "user_id",
          "problem_id",
          "language",
          "source_code"
        ]
      },
      "ScoreboardEntry": {
        "type": "object",
        "properties": {
          "team": {
            "type": "string"
          },
          "solved": {
            "type": "integer"
          },
          "penalty": {
            "type": "integer"
          },
          "problems": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "solved": {
                  "type": "boolean"
                },
                "attempts": {
                  "type": "integer"
                },
                "time": {
                  "type": "integer"
                }
              },
              "required": [
                "solved",
                "attempts"
              ]
            }
          }
        },
        "required": [
          "team",
          "solved",
          "penalty",
          "problems"
        ]
      },
      "Contest": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "title": {
            "type": "string"
