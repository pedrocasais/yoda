{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "id": {
      "type": "integer"
    },
    "username": {
      "type": "string"
    },
    "role": {
      "type": "string",
      "enum": [
        "user",
        "judge",
        "admin"
      ]
    },
    "created_at": {
      "type": "string"
    }
  },
  "required": [
    "id",
    "username",
    "role",
    "created_at"
  ]
}